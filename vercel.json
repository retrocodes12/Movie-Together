{
  "version": 2,
  "installCommand": "npm install && npm --prefix MovieTogether/apps/web install",
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "MovieTogether/apps/web/src/app/api/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
